# ── API-Football (https://dashboard.api-football.com/ — free tier: 100 req/day) ──
API_FOOTBALL_KEY=your_key_here
API_FOOTBALL_HOST=v3.football.api-sports.io

# ── Anthropic Claude API (https://console.anthropic.com/) ──
ANTHROPIC_API_KEY=your_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ── Storage ──────────────────────────────────────────────────
DB_PATH=data/worldcup.db
SNAPSHOT_DIR=data/snapshots
RAW_DATA_DIR=data/raw

# ── Model ────────────────────────────────────────────────────
MODEL_VERSION=v1.0-boosted
SIMULATION_N_RUNS=10000

# ── Streamlit ────────────────────────────────────────────────
STREAMLIT_PORT=8501

# ── Scraper rate limits (seconds between requests) ───────────
FBREF_RATE_LIMIT_SECS=2.0
TRANSFERMARKT_RATE_LIMIT_SECS=3.0
